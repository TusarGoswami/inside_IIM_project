# Environment Variables for The Deal Desk
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (required)
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API Key (required for web research)
TAVILY_API_KEY=your_tavily_api_key_here

# Server Port (optional, defaults to 3001)
PORT=3001

# Postgres connection string for run history persistence (optional)
# Works with any Postgres host — local, Supabase, Neon, Railway, etc.
# If not set, the app still works for live runs, just without history.
DATABASE_URL=postgresql://user:password@localhost:5432/dealdesk
